### Tunnel Provider
# Your Cloudflare Tunnel ID (required)
# Find it: cloudflared tunnel list, or Cloudflare Dashboard > Zero Trust > Tunnels
TUNNEL_ID=

### Default Domain
# The base domain for Dokku and default app hostnames
# Used in docker-compose.yml for DOKKU_HOSTNAME and as the default for new deploys
# Example: example.com -> new apps default to <name>.example.com
DOKKU_HOSTNAME=

### Cloudflare API (auto-configured via `ferry login`)
# API token with Zone:DNS:Edit + Zone:Zone:Read permissions
# https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=

# Cloudflare account ID (auto-discovered from token)
CF_ACCOUNT_ID=
